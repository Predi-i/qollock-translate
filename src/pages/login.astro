---
import AppShell from '../layouts/AppShell.astro';
import { SITE } from '../site.config';

// Standalone, ungated sign-in page. The middleware lets `/login` through; every
// other page redirects here until a GitHub session exists. The "error" query is
// set by /auth/callback when the round trip fails (state mismatch, allowlist).
const error = Astro.url.searchParams.get('error');
---

<AppShell title={`Sign in · ${SITE.appName}`}>
  <main class="login">
    <div class="login-card">
      <div class="brand-mark">{SITE.shortName}</div>
      <h1>{SITE.appName}</h1>
      <p class="sub">
        Translate {SITE.clientName}'s UI strings in your browser. Sign in with GitHub to
        start — your work is opened as a pull request for review.
      </p>
      {error ? <p class="error" role="alert">{error}</p> : null}
      <a class="gh-btn" href="/auth/login">
        <svg viewBox="0 0 16 16" width="18" height="18" aria-hidden="true" fill="currentColor">
          <path
            d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"
          ></path>
        </svg>
        Sign in with GitHub
      </a>
      <p class="foot">
        No account access to {SITE.clientName} is granted — GitHub is used only to
        identify your contributions.
      </p>
    </div>
  </main>
</AppShell>

<style>
  .login {
    min-height: 100dvh;
    display: grid;
    place-items: center;
    padding: 24px;
  }
  .login-card {
    width: 100%;
    max-width: 420px;
    background: var(--color-panel);
    border: 1px solid var(--color-border);
    border-radius: 14px;
    padding: 32px;
    text-align: center;
  }
  .brand-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    margin: 0 auto 16px;
    border-radius: 12px;
    background: var(--color-panel-2);
    border: 1px solid var(--color-border);
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: 20px;
    font-weight: 700;
  }
  h1 {
    margin: 0 0 8px;
    font-size: 22px;
  }
  .sub {
    margin: 0 0 20px;
    color: var(--color-muted);
    font-size: 14px;
    line-height: 1.5;
  }
  .error {
    margin: 0 0 16px;
    padding: 10px 12px;
    border-radius: 8px;
    background: color-mix(in srgb, var(--color-danger) 18%, transparent);
    border: 1px solid var(--color-danger);
    color: var(--color-fg);
    font-size: 13px;
  }
  .gh-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    width: 100%;
    justify-content: center;
    padding: 12px 16px;
    border-radius: 10px;
    background: var(--color-accent);
    color: #101010;
    font-weight: 600;
    text-decoration: none;
  }
  .gh-btn:hover {
    background: color-mix(in srgb, var(--color-accent) 88%, white);
  }
  .foot {
    margin: 18px 0 0;
    color: var(--color-muted);
    font-size: 12px;
    line-height: 1.5;
  }
</style>
