# Copy to `.dev.vars` for local `wrangler dev` or Astro runs.
#
# Production secrets are set with:
#   pnpm exec wrangler secret put CF_ACCESS_TEAM
#   pnpm exec wrangler secret put CF_ACCESS_AUD
#   pnpm exec wrangler secret put GITHUB_TOKEN

CF_ACCESS_TEAM=
CF_ACCESS_AUD=
TRANSLATOR_EMAIL=local-dev@example

# Optional: base URL of a social backend for the in-client suggestion loop
# (/api/live/*). Leave unset to disable that feature.
SOCIAL_BASE_URL=http://localhost:8787

# Fine-grained GitHub PAT for PR creation.
# Required permissions on your target repo (GITHUB_REPO):
#   Contents: Read and write
#   Pull requests: Read and write
GITHUB_TOKEN=
