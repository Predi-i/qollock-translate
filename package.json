{
  "name": "qollock-translate",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "deploy": "pnpm db:migrate:remote && pnpm build && wrangler deploy",
    "astro": "astro",
    "typecheck": "astro check",
    "db:migrate:local": "wrangler d1 migrations apply qollock-translate --local",
    "db:migrate:remote": "wrangler d1 migrations apply qollock-translate --remote",
    "generate-types": "wrangler types"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.5.1",
    "@astrojs/react": "^4.4.0",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^6.3.3",
    "jose": "^5.9.6",
    "lucide-react": "^0.562.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.3.0",
    "wrangler": "^4.92.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "vite": "^7"
  }
}
